NODE_ENV=development
HOST=0.0.0.0
PORT=3001
TRUST_PROXY=false
# >= largest JSON body (bot base64 upload ~4/3 of file size); keep in sync with multipart file cap
BODY_LIMIT_BYTES=16777216
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=72000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=1 minute
RATE_LIMIT_BAN=5
# Must match the bucket name in Supabase Dashboard → Storage (single source of truth).
STORAGE_BUCKET=your-storage-bucket-name
STORAGE_SIGNED_URL_TTL_SECONDS=3600
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
# Must byte-match bot/.env BOT_API_KEY (no quotes, no trailing spaces). Min 16 characters.
BOT_API_KEY=b0c1urwgqfb13uwboi3uqwebkuqjweieuqb
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=2000
# Optional custom CA certificate for strict TLS DB verification.
DB_SSL_CA=
# Postgres connection (pooler or direct). Do not use the Supabase HTTPS project URL here.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_DB_URL=
SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt-from-supabase-dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-from-supabase-dashboard
# Optional but strongly recommended: Dashboard → Settings → API → JWT Secret (local HS256 verify; avoids GoTrue HTTP on every API request).
# SUPABASE_JWT_SECRET=your-jwt-secret
# Comma-separated; these emails get role `admin` in public.users (applied on sync at login / GET /api/auth/me).
ADMIN_EMAILS=politouz@pmsadmin.com
