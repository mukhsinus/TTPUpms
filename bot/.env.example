TELEGRAM_BOT_TOKEN=your-telegram-bot-token
BOT_TOKEN=your-telegram-bot-token
BACKEND_API_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
# Use polling in local dev. In production, set webhook + URL.
BOT_DELIVERY_MODE=polling
# Example: https://your-bot-service.up.railway.app/api/bot/webhook
BOT_WEBHOOK_URL=
# Must byte-match backend BOT_API_KEY (no quotes, no trailing spaces). Min 16 characters.
BOT_API_KEY=replace-with-same-backend-bot-api-key
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
